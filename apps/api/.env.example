DATABASE_URL=postgresql://proseed:proseed@localhost:5432/proseed

# S3 / MinIO (required)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=proseed-uploads

# Optional: defaults to ap-northeast-2
# AWS_REGION=ap-northeast-2

# MinIO endpoint (set this for local development, omit for AWS S3)
S3_ENDPOINT=http://localhost:9000

# Better Auth (required; generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Optional: defaults to http://localhost:3000 for local development
# BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional locally, required in production for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
