{
  "mcpServers": {
    "notion-proseed": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_PROSEED_TOKEN}"
      }
    },
    "figma-proseed": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_PROSEED_TOKEN}"
      }
    }
  }
}
