{
  "mcpServers": {
    "notion-proseed": {
      "command": "direnv",
      "args": [
        "exec",
        ".",
        "sh",
        "-c",
        "NOTION_TOKEN=\"$NOTION_PROSEED_TOKEN\" exec npx -y @notionhq/notion-mcp-server"
      ]
    },
    "figma-proseed": {
      "command": "direnv",
      "args": [
        "exec",
        ".",
        "sh",
        "-c",
        "FIGMA_API_KEY=\"$FIGMA_PROSEED_TOKEN\" exec npx -y figma-developer-mcp --stdio"
      ]
    }
  }
}
